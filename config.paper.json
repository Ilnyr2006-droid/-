{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "dry_run": true,
  "trading_mode": "spot",
  "stake_currency": "USDT",
  "stake_amount": 1000,
  "dry_run_wallet": 10000,
  "max_open_trades": 1,
  "tradable_balance_ratio": 0.1,
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "password": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "SOL/USDT",
      "BNB/USDT",
      "XRP/USDT",
      "ADA/USDT",
      "LINK/USDT",
      "AVAX/USDT"
    ],
    "pair_blacklist": [
      ".*(UP|DOWN|BULL|BEAR)/USDT$",
      ".*(PERP|FUTURES|SWAP).*"
    ]
  },
  "pairlists": [
    {"method": "StaticPairList"}
  ],
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": false,
    "price_last_balance": 0.0,
    "check_depth_of_market": {"enabled": false, "bids_to_ask_delta": 1}
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": false,
    "price_last_balance": 0.0
  },
  "initial_state": "stopped",
  "internals": {"process_throttle_secs": 5}
}
